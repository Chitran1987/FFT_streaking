Isotropic.latt.reduction$`real data`$full_latt <- rec_latt
Isotropic.latt.reduction$`real data`$latt_cut2 <- rec_latt_cut2
Isotropic.latt.reduction$`real data`$latt_cut4 <- rec_latt_cut4
Isotropic.latt.reduction$`real data`$latt_cut6 <- rec_latt_cut6
Isotropic.latt.reduction$`real data`$latt_cut8 <- rec_latt_cut8
