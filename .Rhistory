Isotropic.latt.reduction$fft$latt_cut2 <- rec_latt_fft_cut2
Isotropic.latt.reduction$fft$latt_cut4 <- rec_latt_fft_cut4
Isotropic.latt.reduction$fft$latt_cut6 <- rec_latt_fft_cut6
Isotropic.latt.reduction$fft$latt_cut8 <- rec_latt_fft_cut8
names(Isotropic.latt.reduction$`fft zoom`) <- name_vec
#fft_zoom
Isotropic.latt.reduction$`fft zoom`$full_latt <- rec_latt_fft.zoom
Isotropic.latt.reduction$`fft zoom`$latt_cut2 <- rec_latt_fft.zoom_cut2
Isotropic.latt.reduction$`fft zoom`$latt_cut4 <- rec_latt_fft.zoom_cut4
Isotropic.latt.reduction$`fft zoom`$latt_cut6 <- rec_latt_fft.zoom_cut6
Isotropic.latt.reduction$`fft zoom`$latt_cut8 <- rec_latt_fft.zoom_cut8
#save the data
save(Isotropic.latt.reduction, file = 'IsotropicLattice.rda')
