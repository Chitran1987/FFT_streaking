library(StatsChitran)
library(ImageMetrologyAnalysis)
ClearPlot()
#create the rectangular lattice
X <- seq(0, 20, by=0.05)
Y <- X
rec_latt <- rect.latt(X, Y, R.latt.x = 0.454, R.latt.y = 0.475, A=1, sig = 1)
rec_latt <- rect.latt(X, Y, R.latt.x = 0.454, R.latt.y = 0.475, A=1, sig = 0.1)
help("sigmoid.2D.plat")
#Apply a 2D sigmoid function to this lattice
sig2D <- sigmoid.2D.plat(X, Y, k=8, x.left = 2, x.right = 18, y.left = 2, y.right = 18)
rec_latt_cut2 <- rec_latt
rec_latt_cut2[,,1] <- rec_latt_cut2[,,1]*sig2D
plot2D.arr(arr = rec_latt_cut2)
#cutoff = 4 from edges
sig2D <- sigmoid.2D.plat(X, Y, k=8, x.left = 4, x.right = 16, y.left = 4, y.right = 16)
rec_latt_cut4 <- rec_latt
rec_latt_cut4[,,1] <- rec_latt_cut4[,,1]*sig2D
plot2D.arr(arr = rec_latt_cut4)
#cutoff = 6 from edges
sig2D <- sigmoid.2D.plat(X, Y, k=8, x.left = 6, x.right = 14, y.left = 6, y.right = 14)
rec_latt_cut6 <- rec_latt
rec_latt_cut6[,,1] <- rec_latt_cut6[,,1]*sig2D
plot2D.arr(arr = rec_latt_cut6)
#cutoff = 8 from edges
sig2D <- sigmoid.2D.plat(X, Y, k=8, x.left = 8, x.right = 12, y.left = 8, y.right = 12)
rec_latt_cut8 <- rec_latt
rec_latt_cut8[,,1] <- rec_latt_cut8[,,1]*sig2D
plot2D.arr(arr = rec_latt_cut8)
#plot complete fft of lattice
